{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "outDir": "dist",
    "watchAssets": true,
    "assets": [
      { "include": "../../packages/logic-parser/src/**/*.ts", "watchAssets": true },
      { "include": "../../packages/engine/src/**/*.ts", "watchAssets": true }
    ]
  }
}
