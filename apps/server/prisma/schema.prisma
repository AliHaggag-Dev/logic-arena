generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MatchMode {
  CLASSIC
  TACTICAL
}

enum MatchPhase {
  WAITING
  ROUND_ACTIVE
  BREAK
  FINISHED
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  username             String             @unique
  passwordHash         String?
  googleId             String?            @unique
  githubId             String?            @unique
  avatarUrl            String?
  provider             String?            @default("local") // "local" | "google" | "github"
  isVerified           Boolean            @default(false)
  role                 String             @default("USER")
  verifyCode           String?
  verifyExpiry         DateTime?
  resetCode            String?
  resetExpiry          DateTime?
  rank                 Int                @default(0)
  combatStats          Json? // { efficiency, aggression, defense, precision, speed } (0-100)
  currentLevel              Int                @default(1) // legacy – kept for DB compat
  completedCampaignLevels   String[]           @default([])
  selectedRobotId           String             @default("unit-01")
  selectedColor        String             @default("#22d3ee")
  arenaPreferences     Json? // { defaultRobot, soundFx, music, graphicsQuality }
  notificationSettings Json? // { challengeReqs, tournamentAlerts, matchResults, friendRequests }
  // ── Black Market ──────────────────────────────────────────────────────────
  points               Int                @default(0)
  unlockedItems        String[]           @default([])
  equippedChassis      String             @default("chassis-unit-01")
  equippedPaint        String             @default("paint-default")
  equippedTracer       String             @default("tracer-pulse")
  createdAt            DateTime           @default(now())
  RobotScript          RobotScript[]
  Match                Match[]            @relation("Participants")
  wonMatches           Match[]            @relation("Winner")
  createdTournaments   Tournament[]       @relation("CreatedTournaments")
  tournaments          Tournament[]       @relation("TournamentParticipants")
  matchParticipations  MatchParticipant[]
  achievements         UserAchievement[]
  // ── Friends system ────────────────────────────────────────────────────────
  friendshipsA         Friendship[]       @relation("FriendshipA")
  friendshipsB         Friendship[]       @relation("FriendshipB")
  friendRequestsSent   FriendRequest[]    @relation("FriendRequestSender")
  friendRequestsReceived FriendRequest[]  @relation("FriendRequestReceiver")
  blocksInitiated      Block[]            @relation("BlockInitiator")
  blocksReceived       Block[]            @relation("BlockTarget")
  notifications        Notification[]
}

model RobotScript {
  id                  String             @id @default(uuid())
  title               String
  content             String
  userId              String
  user                User               @relation(fields: [userId], references: [id])
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  matchParticipations MatchParticipant[]
}

model Match {
  id                 String             @id @default(uuid())
  type               String
  mode               MatchMode          @default(CLASSIC)
  roundNumber        Int                @default(1)
  phase              MatchPhase         @default(WAITING)
  roundConfig        Json?
  status             String             @default("pending")
  // pending | in_progress | completed
  winnerId           String?
  winner             User?              @relation(name: "Winner", fields: [winnerId], references: [id])
  participants       User[]             @relation("Participants")
  participantDetails MatchParticipant[]
  duration           Int
  replayData         Json?
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime           @default(now())
}

model MatchParticipant {
  id            String      @id @default(uuid())
  matchId       String
  match         Match       @relation(fields: [matchId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  robotScriptId String
  robotScript   RobotScript @relation(fields: [robotScriptId], references: [id])
  score         Int         @default(0)
  placement     Int? // 1st, 2nd, etc.
  createdAt     DateTime    @default(now())

  @@unique([matchId, userId])
}

model Tournament {
  id           String            @id @default(uuid())
  name         String
  status       String            @default("WAITING")
  // WAITING | IN_PROGRESS | COMPLETED
  creatorId    String
  creator      User              @relation(name: "CreatedTournaments", fields: [creatorId], references: [id])
  participants User[]            @relation("TournamentParticipants")
  matches      TournamentMatch[]
  winnerId     String?
  createdAt    DateTime          @default(now())
}

model TournamentMatch {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  round        Int // 1=Quarter, 2=Semi, 3=Final
  matchIndex   Int // position in bracket
  player1Id    String?
  player2Id    String?
  winnerId     String?
  status       String     @default("PENDING")
  // PENDING | IN_PROGRESS | COMPLETED
  createdAt    DateTime   @default(now())
}

model AriaInsight {
  id        String   @id @default(cuid())
  userId    String
  matchId   String?
  title     String
  content   String
  category  String   @default("general") // performance | energy | tactics | script | general
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model BugReport {
  id          String   @id @default(cuid())
  title       String
  description String
  steps       String?
  severity    String   // LOW | MEDIUM | HIGH | CRITICAL
  status      String   @default("OPEN")
  userId      String?
  createdAt   DateTime @default(now())

  @@index([status])
}

model FeatureRequest {
  id          String   @id @default(cuid())
  title       String
  description String
  useCase     String?
  priority    String   // NICE_TO_HAVE | MODERATE | HIGH | CRITICAL
  status      String   @default("SUBMITTED")
  votes       Int      @default(0)
  userId      String?
  createdAt   DateTime @default(now())

  @@index([status])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("UNREAD")
  createdAt DateTime @default(now())

  @@index([status])
}

model UserAchievement {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId   String    // e.g. "matches_played" | "matches_won" | "rank_score" | "campaign_completed"
  unlockedLevel   Int       @default(0) // 0 = Locked, 1 = Alpha, 2 = Beta, 3 = Gamma, 4 = Delta
  currentProgress Int       @default(0)
  lastUpdated     DateTime  @default(now())
  unlockedAt      DateTime?

  @@unique([userId, achievementId])
  @@index([userId])
}

// ── Friends System ──────────────────────────────────────────────────────────

model Friendship {
  id        String   @id @default(uuid())
  userAId   String   // lexicographically smaller userId
  userBId   String   // lexicographically larger userId
  createdAt DateTime @default(now())

  userA User @relation("FriendshipA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model FriendRequest {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  message    String?  @db.VarChar(200)
  createdAt  DateTime @default(now())
  expiresAt  DateTime // 7 days

  sender   User @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, createdAt])
  @@index([senderId, createdAt])
}

model Block {
  id         String   @id @default(uuid())
  initiatorId String  // user who did the block
  targetId   String   // user who got blocked
  reason     String?  @db.VarChar(200)
  createdAt  DateTime @default(now())

  initiator User @relation("BlockInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  target    User @relation("BlockTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([initiatorId, targetId])
  @@index([initiatorId])
  @@index([targetId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    // recipient
  type      String    // FRIEND_REQUEST | FRIEND_ACCEPTED | CHALLENGE_RECEIVED | MATCH_RESULT | SYSTEM
  title     String    @db.VarChar(120)
  body      String    @db.VarChar(500)
  data      Json?     // { actorId, matchId, requestId, ... }
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

